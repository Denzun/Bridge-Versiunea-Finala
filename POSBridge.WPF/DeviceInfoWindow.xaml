<Window x:Class="POSBridge.WPF.DeviceInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Informații casă de marcat și funcții permise"
        Height="700" Width="750"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- HEADER -->
        <Border Grid.Row="0" 
                Style="{StaticResource ModernCard}" 
                Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="📋 Informații casă de marcat" 
                           FontSize="20" 
                           FontWeight="Bold" 
                           Foreground="{StaticResource TextBrush}"/>
                <TextBlock Text="Date preluate de la dispozitiv + funcții permise FP Protocol" 
                           FontSize="12" 
                           Foreground="#636E72" 
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
        
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- INFORMATII DEVICE -->
                <Border Style="{StaticResource ModernCard}" Margin="0,0,0,15">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="INFORMATII DISPOZITIV" 
                                       FontSize="14" 
                                       FontWeight="SemiBold" 
                                       Foreground="{StaticResource TextBrush}"/>
                            <Button x:Name="RefreshButton"
                                    Grid.Column="1"
                                    Content="🔄 Actualizează informații"
                                    Style="{StaticResource ModernButton}"
                                    Click="RefreshButton_Click"
                                    Padding="12,8"/>
                        </Grid>
                        
                        <TextBlock x:Name="NotConnectedText"
                                   Text="Conectați casa de marcat pentru a vedea informațiile."
                                   Foreground="#636E72"
                                   FontSize="13"
                                   Margin="0,5,0,15"
                                   Visibility="Collapsed"/>
                        
                        <Grid x:Name="InfoGrid" Visibility="Visible">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="180"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Serial fabricație:" Margin="0,4" FontSize="12" Foreground="#636E72"/>
                            <TextBlock x:Name="SerialNumberText" Grid.Row="0" Grid.Column="1" Margin="0,4" FontSize="12" Foreground="{StaticResource TextBrush}" FontFamily="Consolas"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Serie fiscală:" Margin="0,4" FontSize="12" Foreground="#636E72"/>
                            <TextBlock x:Name="FiscalNumberText" Grid.Row="1" Grid.Column="1" Margin="0,4" FontSize="12" Foreground="{StaticResource TextBrush}" FontFamily="Consolas"/>
                            <TextBlock Grid.Row="2" Grid.Column="0" Text="CIF (TAXnumber):" Margin="0,4" FontSize="12" Foreground="#636E72"/>
                            <TextBlock x:Name="TAXnumberText" Grid.Row="2" Grid.Column="1" Margin="0,4" FontSize="12" Foreground="{StaticResource TextBrush}" FontFamily="Consolas"/>
                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Nume dispozitiv:" Margin="0,4" FontSize="12" Foreground="#636E72"/>
                            <TextBlock x:Name="DeviceNameText" Grid.Row="3" Grid.Column="1" Margin="0,4" FontSize="12" Foreground="{StaticResource TextBrush}"/>
                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Firmware:" Margin="0,4" FontSize="12" Foreground="#636E72"/>
                            <TextBlock x:Name="FirmwareText" Grid.Row="4" Grid.Column="1" Margin="0,4" FontSize="12" Foreground="{StaticResource TextBrush}"/>
                            <TextBlock Grid.Row="5" Grid.Column="0" Text="Dată/Ora:" Margin="0,4" FontSize="12" Foreground="#636E72"/>
                            <TextBlock x:Name="DateTimeText" Grid.Row="5" Grid.Column="1" Margin="0,4" FontSize="12" Foreground="{StaticResource TextBrush}"/>
                            <TextBlock Grid.Row="6" Grid.Column="0" Text="Bon deschis:" Margin="0,4" FontSize="12" Foreground="#636E72"/>
                            <TextBlock x:Name="ReceiptOpenText" Grid.Row="6" Grid.Column="1" Margin="0,4" FontSize="12" Foreground="{StaticResource TextBrush}"/>
                            <TextBlock Grid.Row="7" Grid.Column="0" Text="Nr. bon:" Margin="0,4" FontSize="12" Foreground="#636E72"/>
                            <TextBlock x:Name="ReceiptNumberText" Grid.Row="7" Grid.Column="1" Margin="0,4" FontSize="12" Foreground="{StaticResource TextBrush}"/>
                            <TextBlock Grid.Row="8" Grid.Column="0" Text="Header 1:" Margin="0,4" FontSize="12" Foreground="#636E72"/>
                            <TextBlock x:Name="Header1Text" Grid.Row="8" Grid.Column="1" Margin="0,4" FontSize="12" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="9" Grid.Column="0" Text="Header 2:" Margin="0,4" FontSize="12" Foreground="#636E72"/>
                            <TextBlock x:Name="Header2Text" Grid.Row="9" Grid.Column="1" Margin="0,4" FontSize="12" Foreground="{StaticResource TextBrush}" TextWrapping="Wrap"/>
                            <TextBlock Grid.Row="10" Grid.Column="0" Text="TVA A/B/C/D/E:" Margin="0,4" FontSize="12" Foreground="#636E72"/>
                            <TextBlock x:Name="VATText" Grid.Row="10" Grid.Column="1" Margin="0,4" FontSize="12" Foreground="{StaticResource TextBrush}"/>
                            <TextBlock Grid.Row="11" Grid.Column="0" Text="Numerar (Sum/In/Out):" Margin="0,4" FontSize="12" Foreground="#636E72"/>
                            <TextBlock x:Name="CashText" Grid.Row="11" Grid.Column="1" Margin="0,4" FontSize="12" Foreground="{StaticResource TextBrush}"/>
                        </Grid>
                    </StackPanel>
                </Border>
                
                <!-- FUNCTII PERMISE -->
                <Border Style="{StaticResource ModernCard}">
                    <StackPanel>
                        <TextBlock Text="FUNCTII PERMISE (FP Protocol Datecs)" 
                                   FontSize="14" 
                                   FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextBrush}"
                                   Margin="0,0,0,12"/>
                        
                        <ItemsControl x:Name="FunctionsList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#F8F9FA" Padding="8,6" Margin="0,0,0,4" CornerRadius="4">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="12" Foreground="{StaticResource TextBrush}"/>
                                            <TextBlock Text="{Binding Description}" FontSize="11" Foreground="#636E72" Margin="0,2,0,0" TextWrapping="Wrap"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>
